[
  {
    "topic": "convex",
    "en": {
      "q": "A convex lens is what type of lens?",
      "a": "A <strong>converging</strong> lens."
    },
    "zhHant": {
      "q": "凸透鏡係乜嘢透鏡？",
      "a": "<strong>匯聚透鏡</strong>（converging lens）"
    }
  },
  {
    "topic": "convex",
    "en": {
      "q": "Lens ray rule 1?",
      "a": "A ray <strong>parallel</strong> to the principal axis passes through <strong>F</strong> on the other side after refraction."
    },
    "zhHant": {
      "q": "透鏡光線規則 1？",
      "a": "平行於主軸的光線 → 折射後通過另一邊焦點 <strong>F</strong><br>（平衡入，Focus 出）"
    }
  },
  {
    "topic": "convex",
    "en": {
      "q": "Lens ray rule 2?",
      "a": "A ray through <strong>F</strong> emerges <strong>parallel</strong> to the principal axis."
    },
    "zhHant": {
      "q": "透鏡光線規則 2？",
      "a": "通過焦點 <strong>F</strong> 的光線 → 折射後平行於主軸<br>（Focus 入，平衡出）"
    }
  },
  {
    "topic": "convex",
    "en": {
      "q": "Lens ray rule 3?",
      "a": "A ray through the optical centre <strong>C</strong> travels <strong>straight on</strong>."
    },
    "zhHant": {
      "q": "透鏡光線規則 3？",
      "a": "通過光心 <strong>C</strong> 的光線 → 直線通過<br>（C 入 C 出，直入直出）"
    }
  },
  {
    "topic": "convex",
    "en": {
      "q": "Lens formula?",
      "a": "<strong>1/f = 1/u + 1/v</strong>"
    },
    "zhHant": {
      "q": "透鏡公式？",
      "a": "<strong>1/f = 1/u + 1/v</strong>"
    }
  },
  {
    "topic": "convex",
    "en": {
      "q": "In the lens formula, what is <strong>u</strong>?",
      "a": "<strong>Object distance</strong>; always <strong>+ve</strong>."
    },
    "zhHant": {
      "q": "公式中 <strong>u</strong> 代表乜？符號？",
      "a": "物距（object distance）；<strong>恆為正</strong>（+ve）"
    }
  },
  {
    "topic": "convex",
    "en": {
      "q": "In the lens formula, what is <strong>v</strong>?",
      "a": "<strong>Image distance</strong><br>Real image: <strong>+ve</strong><br>Virtual image: <strong>−ve</strong>"
    },
    "zhHant": {
      "q": "公式中 <strong>v</strong> 代表乜？符號約定？",
      "a": "像距（image distance）<br>實像：<strong>+ve</strong><br>虛像：<strong>−ve</strong>"
    }
  },
  {
    "topic": "convex",
    "en": {
      "q": "Sign of focal length <strong>f</strong> for a convex lens?",
      "a": "<strong>+ve</strong> (positive)."
    },
    "zhHant": {
      "q": "凸透鏡焦距 <strong>f</strong> 嘅符號？",
      "a": "<strong>+ve</strong>（正）"
    }
  },
  {
    "topic": "convex",
    "en": {
      "q": "Linear magnification formula?",
      "a": "<strong>M = v/u = h<sub>i</sub>/h<sub>o</sub></strong>"
    },
    "zhHant": {
      "q": "線性放大率 <strong>M</strong> 公式？",
      "a": "<strong>M = v/u = h<sub>i</sub>/h<sub>o</sub></strong>"
    }
  },
