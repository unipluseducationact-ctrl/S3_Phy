  "bands": {
    "radio": {
      "en": {
        "name": "Radio waves",
        "examples": [
          "AM/FM broadcasting",
          "TV signals",
          "Long-wavelength radar"
        ],
        "implications": "Longest wavelengths, lowest frequencies. Non-ionizing. Good diffraction around obstacles. Low photon energy."
      },
      "zh": {
        "name": "無線電波",
        "examples": [
          "調幅／調頻廣播",
          "電視訊號",
          "長波雷達"
        ],
        "implications": "波長最長、頻率最低。非電離輻射。繞射能力強。光子能量低。"
      }
    },
    "microwave": {
      "en": {
        "name": "Microwaves",
        "examples": [
          "Microwave ovens (heating water)",
          "Wi-Fi and Bluetooth",
          "Satellite communication"
        ],
        "implications": "Absorbed by water molecules, causing heating. Still non-ionizing. Used for radar and wireless data."
      },
      "zh": {
        "name": "微波",
        "examples": [
          "微波爐（加熱水分）",
          "Wi-Fi 與藍牙",
          "衛星通訊"
        ],
        "implications": "被水分子吸收而產生熱。仍屬非電離。用於雷達與無線數據。"
      }
    },
    "infrared": {
      "en": {
        "name": "Infrared",
        "examples": [
          "Thermal imaging",
          "TV remote controls",
          "Night-vision heat signatures"
        ],
        "implications": "Felt as heat. Emitted by warm objects. Higher frequency than microwaves, but still non-ionizing."
      },
      "zh": {
        "name": "紅外線",
        "examples": [
          "熱成像",
          "電視遙控",
          "夜視熱影像"
        ],
        "implications": "以熱能形式感受。溫暖物體會輻射。頻率高於微波，仍非電離。"
      }
    },
    "visible": {
      "en": {
        "name": "Visible light",
        "examples": [
          "Human vision (~400-700 nm)",
          "Fiber-optic communications",
          "Photosynthesis"
        ],
        "implications": "The narrow band our eyes detect. Each color is a different wavelength and frequency."
      },
      "zh": {
        "name": "可見光",
        "examples": [
          "人眼視覺（約 400–700 nm）",
          "光纖通訊",
          "光合作用"
        ],
        "implications": "人眼可感應的窄波段。不同顏色對應不同波長與頻率。"
      }
    },
    "uv": {
      "en": {
        "name": "Ultraviolet",
        "examples": [
          "Sun tanning and sunburn",
          "Sterilization lamps",
          "Fluorescent black lights"
        ],
        "implications": "Higher frequency means more energetic photons. Can damage skin. Ionizing with prolonged exposure."
      },
      "zh": {
        "name": "紫外線",
        "examples": [
          "曬黑與曬傷",
          "紫外消毒燈",
          "螢光黑光燈"
        ],
        "implications": "頻率較高，光子能量較大。可損傷皮膚。長時間暴露具電離性。"
      }
    },
    "xray": {
      "en": {
        "name": "X-rays",
        "examples": [
          "Medical and dental imaging",
          "Airport security scanners",
          "Crystallography"
        ],
        "implications": "Short wavelength, penetrates soft tissue but absorbed by bone. Ionizing at high doses."
      },
      "zh": {
        "name": "X 射線",
        "examples": [
          "醫學與牙科造影",
          "機場安檢掃描",
          "晶體學"
        ],
        "implications": "波長短，可穿透軟組織但被骨骼吸收。高劑量具電離性。"
      }
    },
    "gamma": {
      "en": {
        "name": "Gamma rays",
        "examples": [
          "Nuclear decay",
          "Cancer radiotherapy",
          "Gamma-ray bursts in space"
        ],
        "implications": "Shortest wavelength, highest frequency, most energetic photons. Highly ionizing and penetrating."
      },
      "zh": {
        "name": "伽馬射線",
        "examples": [
          "核衰變",
          "癌症放射治療",
          "宇宙伽馬暴"
        ],
        "implications": "波長最短、頻率最高、光子能量最大。高度電離且穿透力強。"
      }
    }
  },
